# Aeolus Environment Configuration

# MQTT Broker
MQTT_BROKER_URL=mqtt://localhost:1883
MQTT_TOPICS=sensor/#,switch/#,motion/#,light/#

# Backend API
PORT=3001

# Philips Hue Integration (optional)
HUE_BRIDGE_IP=
HUE_API_KEY=

# Database
DB_PATH=./data/aeolus.db

# Logging
LOG_LEVEL=debug

# Environment
NODE_ENV=development
